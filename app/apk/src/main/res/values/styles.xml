<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Widget.App.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#E8DEF8</item>
        <item name="android:width">64dp</item>
        <item name="android:height">32dp</item>
    </style>

    <style name="Widget.Foundation.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemActiveIndicatorStyle">@style/Widget.App.ActiveIndicator</item>
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="labelVisibilityMode">unlabeled</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Theme.Foundation.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#6750A4</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondaryContainer">#E8DEF8</item>
        <item name="colorSurface">#FFFBFE</item>
        <item name="colorSurfaceVariant">#F2F2F2</item> <item name="colorOnSurface">#1C1B1F</item>

        <item name="android:windowBackground">#FFFBFE</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">true</item>

        <item name="materialCardViewStyle">@style/Widget.Foundation.CardView</item>
        <item name="bottomNavigationStyle">@style/Widget.Foundation.BottomNavigationView</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Foundation.Dialog</item>
    </style>

    <style name="Theme.Foundation" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#D0BCFF</item>
        <item name="colorSurface">#1C1B1F</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="android:windowBackground">#1C1B1F</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <item name="materialCardViewStyle">@style/Widget.Foundation.CardView</item>
        <item name="bottomNavigationStyle">@style/Widget.Foundation.BottomNavigationView</item>
    </style>

    <style name="ThemeOverlay.Foundation.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Dialog</item>
        <item name="materialButtonStyle">@style/Widget.Material3.Button.TextButton</item>
    </style>

    <style name="Widget.Foundation.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">#F2F2F2</item> <item name="cardElevation">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Card</item>
    </style>

    <style name="ShapeAppearance.App.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearance.App.Dialog" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">28dp</item>
    </style>

</resources>